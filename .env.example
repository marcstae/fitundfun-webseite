# PocketBase — comma-separated list of origins allowed to access the PB API
# Include the URL where the website is served (the web container's public URL)
PB_ORIGINS=http://192.168.1.169:3843

# Public URL where browsers can reach PocketBase (used by Next.js at build time)
NEXT_PUBLIC_PB_URL=http://192.168.1.169:3844

# Public URL where the website is served (used for sitemap, metadata, SEO)
SITE_URL=http://192.168.1.169:3843

# Secret for Next.js on-demand revalidation API (/api/revalidate)
REVALIDATE_SECRET=CHANGE_THIS_GENERATE_A_RANDOM_SECRET
